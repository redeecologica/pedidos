# Copie para scripts/prod.env (gitignored) e preencha.
# NUNCA commitar o arquivo preenchido.

# SSH (mesmas credenciais do FTP na Locaweb, em geral)
PROD_SSH_USER="usuario"
PROD_SSH_HOST="ssh.seudominio.com.br"
# Caminho do docroot do sistema no servidor (ex.: /home/usuario/public_html/pedidos)
PROD_WEB_ROOT="/caminho/ate/o/docroot"

# Banco de produção (copie de settings.php de produção — prod-snapshot/settings.php após o download do snapshot)
PROD_DB_HOST="ip.ou.host.mysql"
PROD_DB_NAME="nome_do_banco"
PROD_DB_USER="usuario_do_banco"
PROD_DB_PASS="senha_do_banco"